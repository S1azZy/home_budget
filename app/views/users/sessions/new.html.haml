%section.hero.is-success.is-fullheight
  .hero-body
    .container.has-text-centered
      .column.is-4.is-offset-4
        %h3.title.has-text-black Login
        %hr.login-hr/
        %p.subtitle.has-text-black Please login to proceed.
        .box
          = form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
            .field.control
              = f.email_field :email, autofocus: "", autocomplete: "email", placeholder: "Your Email", class: "input is-large"
            .field.control
              = f.password_field :password, autocomplete: "current-password", class: "input is-large", placeholder: "Your Password"
            .field
              %label.checkbox
                = f.check_box :remember_me
                = f.label :remember_me
            %button.button.is-block.is-info.is-large.is-fullwidth{type: "submit"}
              Login
              %i.fa.fa-sign-in{"aria-hidden" => "true"}
        %p.has-text-grey
          = render "users/shared/links"
