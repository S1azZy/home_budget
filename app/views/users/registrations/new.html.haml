%section.hero.is-success.is-fullheight
  .hero-body
    .container.has-text-centered
      .column.is-4.is-offset-4
        %h3.title.has-text-black Sign up
        %hr.login-hr/
        %p.subtitle.has-text-black Please enter your data.
        .box
          = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
            = render "users/shared/error_messages", resource: resource
            .field.control
              = f.text_field :first_name, placeholder: "First name", class: "input is-large"
            .field.control
              = f.text_field :last_name, placeholder: "Last name", class: "input is-large"
            .field.control
              = f.email_field :email, autofocus: "", autocomplete: "email", placeholder: "Your Email", class: "input is-large"
            .field.control
              = f.password_field :password, autocomplete: "new-password", class: "input is-large", placeholder: "Enter your password"
            .field.control
              = f.password_field :password_confirmation, autocomplete: "new-password", class: "input is-large", placeholder: "Confirm your password"
            %button.button.is-block.is-info.is-large.is-fullwidth{type: "submit"}
              Sign up
              %i.fa.fa-sign-in{"aria-hidden" => "true"}
